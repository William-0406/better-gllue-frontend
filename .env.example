# 复制本文件为 .env.local，填入你们的真实地址后再 build。
# .env.local 已被 .gitignore 忽略，不会提交到仓库。

# 谷露 CRM 主机（host，可带端口）。扩展会注入到 http://<这里>/crm
VITE_GLLUE_HOST=your-gllue-host.example.com

# 增强服务器（候选人查重 + 百度 OCR 代理），格式 host:port；没有就留空。
VITE_ENHANCE_HOST=

# 以下仅“增强服务器”服务端需要（server/gllue-enhance-api），前端用不到。
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
